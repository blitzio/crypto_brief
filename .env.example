# Copy these names into your Cloudflare Worker secrets/variables.
# Do not put real secret values in this file.

GEMINI_API_KEY=replace-with-google-ai-studio-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
GEMINI_THINKING_LEVEL=low
BRIEF_PIPELINE_VERSION=v2
ALLOWED_ORIGINS=https://your-username.github.io
BRIEF_ADMIN_TOKEN=optional-manual-save-token
COINGECKO_DEMO_API_KEY=optional-coingecko-demo-key
