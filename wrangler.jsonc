{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "crypto-brief-proxy",
  "main": "worker.js",
  "compatibility_date": "2026-03-26",
  "vars": {
    "GEMINI_MODEL": "gemini-3.5-flash",
    "GEMINI_FALLBACK_MODEL": "gemini-3.1-flash-lite",
    "GEMINI_THINKING_LEVEL": "low",
    "GEMINI_V3_THINKING_LEVEL": "medium",
    "BRIEF_PIPELINE_VERSION": "v3",
    "NEWS_ENRICHMENT_ENABLED": "false",
    "ALLOWED_ORIGINS": "https://blitzio.github.io"
  },
  "kv_namespaces": [
    {
      "binding": "BRIEF_CACHE",
      "id": "296f56cf316b4fe49c132b7bf25bd482"
    }
  ]
}
